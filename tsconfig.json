{
	"compilerOptions": {
		"target": "ES2018",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"strict": true,
		"noEmit": true,
		"allowJs": true,
		"checkJs": false,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"lib": ["ES2018", "DOM", "DOM.Iterable"]
	},
	"include": ["src/**/*"]
}
